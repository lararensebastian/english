    {
      "id": "swedish-mistakes",
      "title": "Svenska översättningsfällor",
      "icon": "🍕",
      "level": "A2–B1",
      "time": "60–90 min",
      "desc": "Sluta översätta ord för ord. Träna vanliga fraser + skriv egna bättre meningar.",
      "parts": [
        {
          "type": "lesson",
          "title": "Mini-lesson: Don’t translate word-for-word",
          "content": [
            "Många svenska fraser låter konstiga på engelska om du översätter direkt.",
            "Lösning: lär dig EN naturlig engelsk fras (chunk) i taget.",
            "Regel: välj hellre en enkel naturlig mening än en avancerad direktöversättning."
          ]
        },
        {
          "type": "mc",
          "title": "Quick check (10 frågor)",
          "items": [
            {
              "q": "Hur säger man 'Jag ska gå och lägga mig' bäst?",
              "opts": [
                "I will go and lay me",
                "I'm going to bed",
                "I will go and put myself"
              ],
              "a": 1,
              "exp": "'I'm going to bed' är naturligt."
            },
            {
              "q": "Bäst engelska för 'Hur mår du?'",
              "opts": [
                "How is it with you?",
                "How are you?",
                "How is with you?"
              ],
              "a": 1,
              "exp": "'How are you?' är standard."
            },
            {
              "q": "'Jag fryser'",
              "opts": [
                "I'm cold",
                "I'm cold on me",
                "I'm a cold person"
              ],
              "a": 0,
              "exp": "'I'm cold' = jag fryser."
            },
            {
              "q": "'Jag ska till stan'",
              "opts": [
                "I'm going to the city",
                "I'm going into town",
                "I'm going to the town"
              ],
              "a": 1,
              "exp": "'into town'/'downtown' är bäst."
            },
            {
              "q": "'Jag är 15 år'",
              "opts": [
                "I have 15 years",
                "I am 15 years old",
                "I am 15 years"
              ],
              "a": 1,
              "exp": "Engelska använder 'am' + 'years old'."
            },
            {
              "q": "'Kan jag låna din penna?'",
              "opts": [
                "Can I borrow your pen?",
                "Can I lend your pen?",
                "Can I loan you your pen?"
              ],
              "a": 0,
              "exp": "Borrow = låna (ta). Lend = låna ut."
            },
            {
              "q": "'Jag ska baka småkakor'",
              "opts": [
                "I will bake cookies",
                "I will bake cakes",
                "I will cook cookies"
              ],
              "a": 0,
              "exp": "Cookies = småkakor."
            },
            {
              "q": "'Jag ser fram emot det'",
              "opts": [
                "I'm looking forward to it",
                "I look forward that",
                "I'm seeing forward to it"
              ],
              "a": 0,
              "exp": "'look forward to' + noun/ing."
            },
            {
              "q": "'Jag gillar musik'",
              "opts": [
                "I like music",
                "I like to music",
                "I like on music"
              ],
              "a": 0,
              "exp": "Ingen preposition behövs."
            },
            {
              "q": "'Jag ska ta en dusch'",
              "opts": [
                "I will take a shower",
                "I will do a shower",
                "I will make a shower"
              ],
              "a": 0,
              "exp": "'take a shower' är naturligt."
            }
          ]
        },
        {
          "type": "fix",
          "title": "Fix the sentence (8)",
          "items": [
            {
              "bad": "How is it with you?",
              "good": "How are you?",
              "why": "Vanlig fras."
            },
            {
              "bad": "I have 16 years.",
              "good": "I am 16 years old.",
              "why": "Ålder uttrycks med 'am'."
            },
