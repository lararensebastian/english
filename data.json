{
  "modules": [
    {
      "id": "prepositions",
      "title": "Prepositions: IN / ON / AT",
      "icon": "📍",
      "level": "A2–B1",
      "time": "60–90 min",
      "desc": "Träna IN/ON/AT med förståelse, fix-the-mistake, bygg meningar, reading och writing.",
      "rules": [
        {
          "heading": "IN",
          "text": "Countries, cities, years, months, long periods (in Sweden, in 2012, in July)."
        },
        {
          "heading": "ON",
          "text": "Days and dates (on Monday, on 5th May)."
        },
        {
          "heading": "AT",
          "text": "Exact time and specific points/places (at 3 o'clock, at the bus stop)."
        }
      ],
      "parts": [
        {
          "type": "lesson",
          "title": "Understand the rule",
          "content": [
            "IN = länder/städer/år/månader/längre perioder",
            "ON = dagar/datum",
            "AT = exakta tider + specifika punkter/platser",
            "Tips: tänk IN (inne i), ON (på en dag), AT (en punkt)."
          ]
        },
        {
          "type": "mc",
          "title": "Quick check (10 frågor)",
          "items": [
            {
              "q": "I live ___ Sweden.",
              "opts": [
                "in",
                "on",
                "at"
              ],
              "a": 0,
              "exp": "IN för länder/städer/områden."
            },
            {
              "q": "The meeting is ___ Monday.",
              "opts": [
                "in",
                "on",
                "at"
              ],
              "a": 1,
              "exp": "ON för dagar och datum."
            },
            {
              "q": "I'll meet you ___ 3 o'clock.",
              "opts": [
                "in",
                "on",
                "at"
              ],
              "a": 2,
              "exp": "AT för exakta tidpunkter."
            },
            {
              "q": "She was born ___ 1995.",
              "opts": [
                "in",
                "on",
                "at"
              ],
              "a": 0,
              "exp": "IN för år/månader/säsonger."
            },
            {
              "q": "I'm waiting ___ the bus stop.",
              "opts": [
                "in",
                "on",
                "at"
              ],
              "a": 2,
              "exp": "AT för specifika platser/punkter."
            },
            {
              "q": "We have English ___ Fridays.",
              "opts": [
                "in",
                "on",
                "at"
              ],
              "a": 1,
              "exp": "ON Fridays."
            },
            {
              "q": "My birthday is ___ June.",
              "opts": [
                "in",
                "on",
                "at"
              ],
              "a": 0,
              "exp": "IN June."
            },
            {
              "q": "The train leaves ___ 07:15.",
              "opts": [
                "in",
                "on",
                "at"
              ],
              "a": 2,
              "exp": "AT 07:15."
            },
            {
              "q": "I usually study ___ the evening.",
              "opts": [
                "in",
                "on",
                "at"
              ],
              "a": 0,
              "exp": "IN the evening (vanlig fras)."
            },
            {
              "q": "Let's meet ___ the entrance.",
              "opts": [
                "in",
                "on",
                "at"
              ],
              "a": 2,
              "exp": "AT the entrance."
            }
          ]
        },
        {
          "type": "fix",
          "title": "Fix the mistakes (8 meningar)",
          "items": [
            {
              "bad": "I was born at 2005.",
              "good": "I was born in 2005.",
              "why": "IN för år."
            },
            {
              "bad": "The meeting is in Monday.",
              "good": "The meeting is on Monday.",
              "why": "ON för dagar."
            },
            {
              "bad": "I'll call you in 8 o'clock.",
              "good": "I'll call you at 8 o'clock.",
              "why": "AT för exakt tid."
            },
            {
              "bad": "She lives at Sweden.",
              "good": "She lives in Sweden.",
              "why": "IN för länder."
            },
            {
              "bad": "We met in Friday.",
              "good": "We met on Friday.",
              "why": "ON för dagar."
            },
            {
              "bad": "He arrived on 2019.",
              "good": "He arrived in 2019.",
              "why": "IN för år."
            },
            {
              "bad": "Class starts in 09:00.",
              "good": "Class starts at 09:00.",
              "why": "AT för exakt tid."
            },
            {
              "bad": "I'm at home on the evening.",
              "good": "I'm at home in the evening.",
              "why": "IN the evening."
            }
          ]
        },
        {
