        {
          "type": "reading",
          "title": "Mini reading (A2–B1)",
          "text": "Emma lives in London. She works at a bank near the river. She was born in 1998. On Mondays, she starts work at 8:30. In the evening, she studies English at home. At the weekend, she meets friends in the city.",
          "questions": [
            {
              "q": "Where does Emma live?",
              "a": "She lives in London.",
              "hint": "Use 'in' + place."
            },
            {
              "q": "Where does she work?",
              "a": "She works at a bank.",
              "hint": "Use 'at' + specific place."
            },
            {
              "q": "When was she born?",
              "a": "She was born in 1998.",
              "hint": "Use 'in' + year."
            },
            {
              "q": "What time does she start work on Mondays?",
              "a": "She starts work at 8:30 on Mondays.",
              "hint": "Use 'at' for time and 'on' for day."
            },
            {
              "q": "Where does she study in the evening?",
              "a": "She studies English at home in the evening.",
              "hint": "Combine 'at' + place and 'in' + time period."
            }
          ]
        },
        {
          "type": "writing",
          "title": "Writing task (30–45 min)",
          "prompt": "Write 10 sentences about your life. Use:\n• 3 sentences with IN\n• 3 sentences with ON\n• 3 sentences with AT\n• 1 free sentence\n\nTry to write about real things (home, school, hobbies, times, days).",
          "checklist": [
            "I used IN correctly (countries/cities/years/months/long periods).",
            "I used ON correctly (days/dates).",
            "I used AT correctly (exact times/specific places).",
